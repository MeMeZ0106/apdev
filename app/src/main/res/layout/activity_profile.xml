<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Profile"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/neon_pink"
            app:titleTextColor="@color/neon_pink" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgProfile"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="32dp"
            android:src="@drawable/ic_person"
            app:tint="@color/neon_pink" />

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Guest User"
            android:textColor="@color/neon_pink"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <!-- Role badge: shown only when a role is resolved -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Customer"
            android:textColor="@color/on_primary"
            android:visibility="gone"
            app:chipBackgroundColor="@color/neon_pink"
            app:chipStrokeWidth="0dp"
            style="@style/Widget.Material3.Chip.Assist" />

        <TextView
            android:id="@+id/tvProfileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="guest@example.com"
            android:textColor="@color/white"
            android:textSize="16sp"/>

        <!-- Sign-in provider badge -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipProvider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Email / Password"
            android:textColor="@color/on_primary"
            android:visibility="gone"
            app:chipBackgroundColor="@color/neon_pink"
            app:chipStrokeWidth="0dp"
            style="@style/Widget.Material3.Chip.Assist" />

        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Edit Profile"
            android:backgroundTint="@color/neon_pink"
            android:textColor="@color/on_primary"/>

        <!-- Only shown for email/password accounts -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangePassword"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_change_password"
            android:visibility="gone"
            app:strokeColor="@color/neon_pink"
            app:cornerRadius="12dp"
            android:textColor="@color/neon_pink" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

