<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.SanzinKstore" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Day mode: warm cream + dark reds -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <!-- Red status bar to match red toolbar — needs dark (light) icons = false -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOutline">@color/outline</item>

        <!-- Red toolbar for day mode -->
        <item name="toolbarStyle">@style/Widget.App.Toolbar.Primary</item>
        <item name="appBarLayoutStyle">@style/Widget.App.AppBarLayout.Primary</item>
    </style>

    <!-- Red toolbar style -->
    <style name="Widget.App.Toolbar.Primary" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/on_primary</item>
        <item name="subtitleTextColor">@color/on_primary</item>
        <item name="navigationIconTint">@color/on_primary</item>
    </style>

    <!-- Red AppBarLayout (prevents white flash on scroll) -->
    <style name="Widget.App.AppBarLayout.Primary" parent="Widget.Material3.AppBarLayout">
        <item name="android:background">@color/primary</item>
    </style>

    <style name="RoundedSquareTop">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">12dp</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="Theme.SanzinKstore" parent="Base.Theme.SanzinKstore" />

    <style name="CustomDialogTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
</resources>